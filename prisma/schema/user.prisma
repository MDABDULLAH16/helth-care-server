model User {
    id               String     @id @default(uuid())
    name             String
    email            String     @unique
    password         String
    needPasswordHash Boolean    @default(true)
    role             UserRole   @default(PATIENT)
    status           UserStatus @default(ACTIVE)
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt
    admin            Admin?
    doctor           Doctor?
    patient          Patient?

    @@map("users")
}
